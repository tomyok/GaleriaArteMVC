@model List<Obra>
@{
}

<h1>Seleccion de obras</h1>

<form asp-action="SeleccionObras" method="post">

    <input type="hidden" name="expoId" value="@ViewBag.idExpo"/>
    <table class="table">
        <thead>
            <tr>
                <th>Titulo</th>
                <th>Imagen</th>
                <th>Seleccion</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obra in Model)
                {
                    <tr>
                        <td>@obra.Titulo</td>
                        @* <td>@obra.Artista.Nombre</td> *@
                        <td><img src="@obra.UrlImagen" height="50"/></td>
                        <td>
                            <input type="checkbox" class="form-check" name="obraIds" value="@obra.Id"/>
                        </td>
                    </tr>
                }

        </tbody>
    </table>
    <button type="submit" class="btn btn-primary">Agregar</button>

</form>